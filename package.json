{
  "name": "exporter-browser",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Browser extension that exports ChatGPT/Claude conversations to AIUSE-spec markdown logs.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aiusemd/exporter-browser.git"
  },
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "package": "node scripts/package.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@crxjs/vite-plugin": "2.4.0",
    "@playwright/test": "^1.59.1",
    "@preact/preset-vite": "^2.10.5",
    "@testing-library/preact": "^3.2.4",
    "@types/chrome": "^0.1.40",
    "@types/node": "22.12.0",
    "autoprefixer": "^10.5.0",
    "fflate": "^0.8.2",
    "happy-dom": "^20.9.0",
    "postcss": "^8.5.12",
    "tailwindcss": "3.4.13",
    "typescript": "5.6.3",
    "vite": "^8.0.10",
    "vitest": "2.1.2"
  },
  "dependencies": {
    "client-zip": "^2.5.0",
    "preact": "^10.29.1"
  }
}
